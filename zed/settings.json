{
  "icon_theme": "Air Icons Dark",
  "theme": "Air Dark Italic",
  "cli_default_open_behavior": "new_window",
  "diff_view_style": "split",
  "agent": {
    "default_profile": "claude-code"
  },
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "format_on_save": "off",
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "JSON": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "Vue.js": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    }
  },
}
