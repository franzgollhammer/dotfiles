{
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  // "ui_font_size": 17.0,
  "buffer_font_size": 13.0,
  "edit_predictions": {
    "provider": "copilot",
  },
  // "buffer_font_size": 13.0,
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    // "font_size": 13.0,
    "font_size": 13.0,
    "cursor_shape": "bar",
  },
  "project_panel": {
    "dock": "right",
    "bold_folder_labels": true,
    "folder_icons": false,
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
  },
  "icon_theme": {
    "mode": "system",
    "light": "Air + Material Icons Light",
    "dark": "Air + Material Icons Dark",
  },
  "theme": {
    "mode": "system",
    "light": "Air Light Italic",
    "dark": "Air Dark Italic",
  },
  "cli_default_open_behavior": "new_window",
  "diff_view_style": "unified",
  "tabs": {
    "file_icons": true,
  },
  "colorize_brackets": true,
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 1,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
  },
  "agent": {
    "dock": "left",
    "thinking_display": "always_collapsed",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
      "enable_thinking": false,
    },
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": true,
      "effort": "medium",
    },
    "default_profile": "write",
    "commit_message_model": {
      "provider": "zed.dev",
      "model": "claude-haiku-4-5",
    },
  },
  "agent_servers": {
    "gemini": {
      "type": "registry",
    },
    "cursor": {
      "type": "registry",
    },
    "codex-acp": {
      "default_config_options": {
        "mode": "full-access",
      },
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "effort": "high",
        "mode": "bypassPermissions",
      },
      "type": "registry",
    },
  },
  "format_on_save": "off",
  "languages": {
    "Markdown": {
      "format_on_save": "on",
    },
    "JSONC": {
      "format_on_save": "on",
    },
    "JSON": {
      "format_on_save": "on",
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "format_on_save": "on",
      "formatter": [],
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "format_on_save": "on",
      "formatter": [],
    },
    "Vue.js": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "format_on_save": "on",
      "formatter": [],
    },
  },
}
