{
  "agent_servers": {
    "claude": {
      "favorite_config_option_values": {
        "mode": ["bypassPermissions"]
      }
    }
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "git_panel": {
    "tree_view": true,
    "sort_by_path": false
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "title_bar": {
    "show_menus": false,
    "show_branch_icon": false
  },
  "file_types": {
    "GitHub Actions": [".github/workflows/*.yml", ".github/workflows/*.yaml"]
  },
  "lsp": {
    "gh-actions-language-server": {
      "initialization_options": {
        "sessionToken": "" // set to PAT for more information
      }
    }
  },
  "languages": {
    "Git Commit": {
      "tab_size": 2
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "cat << EOF",
          "arguments": []
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "cat << EOF",
          "arguments": []
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "Vue.js": {
      "formatter": {
        "external": {
          "command": "cat << EOF",
          "arguments": []
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    }
  }
}
