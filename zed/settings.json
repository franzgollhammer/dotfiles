{
  "buffer_font_size": 12.0,
  "terminal": {
    "font_size": 12.0,
  },
  "icon_theme": {
    "mode": "system",
    "light": "Air Icons Light",
    "dark": "Air Icons Dark",
  },
  "theme": {
    "mode": "system",
    "light": "Air Light Italic",
    "dark": "Air Dark Italic",
  },
  "cli_default_open_behavior": "new_window",
  "diff_view_style": "split",
  "tabs": {
    "file_icons": true,
  },
  "colorize_brackets": true,
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 1,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
  },
  "agent": {
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": true,
      "effort": "medium"
    },
    "default_profile": "write",
    "commit_message_model": {
      "provider": "zed.dev",
      "model": "claude-haiku-4-5",
    },
  },
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "format_on_save": "off",
  "languages": {
    "Markdown": {
      "format_on_save": "on",
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "format_on_save": "on",
      "formatter": [],
    },
    "JSONC": {
      "format_on_save": "on",
    },
    "JSON": {
      "format_on_save": "on",
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "format_on_save": "on",
      "formatter": [],
    },
    "Vue.js": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "format_on_save": "on",
      "formatter": [],
    },
  },
}
