{
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "ui_font_size": 16,
  "buffer_font_size": 12,
  "icon_theme": {
    "mode": "system",
    "light": "Colored Zed Icons Theme Light",
    "dark": "Colored Zed Icons Theme Dark"
  },
  "theme": {
    "mode": "system",
    "light": "Xcode Classic Light",
    "dark": "Xcode Classic Darker"
  },
  "git_panel": {
    "tree_view": true
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "buffer_font_family": "Lilex Nerd Font",
  "inlay_hints": {
    // "enabled": true
  },
  "format_on_save": "off",
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "JSON": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "Vue.js": {
      "language_servers": ["vue-language-server", "intl-lens", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    }
  },
  "lsp": {
    "intl-lens": {
      "binary": { "path": "/Users/fg/.local/bin/intl-lens" }
    }
  },
  "agent": {
    "commit_message_model": {
      "provider": "zed.dev",
      "model": "claude-haiku-4-5"
    }
  }
}
