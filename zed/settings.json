{
  "icon_theme": "Air Icons Dark",
  "theme": "Air Dark Italic",
  "cli_default_open_behavior": "new_window",
  "diff_view_style": "split",
  "tabs": {
    "file_icons": true
  },
  "colorize_brackets": true,
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 1,
    "coloring": "indent_aware",
    "background_coloring": "disabled"
  },
  "agent": {
    "default_profile": "claude-code",
    "commit_message_model": {
      "provider": "zed.dev",
      "model": "claude-haiku-4-5"
    }
  },
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "format_on_save": "off",
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "JSON": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "Vue.js": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    }
  },
}
