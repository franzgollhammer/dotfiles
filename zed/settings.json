{
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  // "icon_theme": {
  //   "mode": "system",
  //   "light": "JetBrains New UI Icons (Light)",
  //   "dark": "JetBrains New UI Icons (Dark)"
  // },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "git_panel": {
    "tree_view": true
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "buffer_font_family": "Lilex Nerd Font",
  "inlay_hints": {
    // "enabled": true
  },
  "format_on_save": "off",
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "JSON": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    },
    "Vue.js": {
      "language_servers": ["vue-language-server", "intl-lens", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on",
      "formatter": []
    }
  },
  "lsp": {
    "intl-lens": {
      "binary": { "path": "/Users/fg/.local/bin/intl-lens" }
    }
  },
  "agent": {
    "expand_terminal_card": false,
    "expand_edit_card": false,
    "commit_message_model": {
      "provider": "zed.dev",
      "model": "claude-haiku-4-5"
    }
  }
}
