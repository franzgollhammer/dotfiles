# install from pre-release channel
auto-update-channel = tip
macos-icon = holographic

# theme
theme = dark:air-dark,light:air-light
# background-opacity = 0.95
window-padding-x = 8
window-padding-y = 8
font-family  = JetBrainsMono Nerd Font
font-size = 13

# keybinds
keybind = global:cmd+#=toggle_visibility

# cursor
cursor-style = block
cursor-style-blink = false

# macOS
font-thicken = true

# clipboard
copy-on-select = clipboard
clipboard-read = allow
clipboard-write = allow

# mouse
mouse-hide-while-typing = true

# window
confirm-close-surface = false
window-save-state = always
window-inherit-font-size = true

# text
bold-color = bright
adjust-cell-height = 30%
scrollback-limit = 10000

# notifications (desktop notification on bell)
bell-features = system,attention,title
desktop-notifications = true

# shell integration
shell-integration-features = no-cursor,sudo,title
