#!/bin/bash
# tmux_worktree - fzf sessionizer for git worktrees

set -euo pipefail

if [[ -z "$TMUX" ]]; then
  echo "Not in a tmux session"
  exit 1
fi

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [[ -z "$REPO_ROOT" ]]; then
  echo "Not in a git repo"
  exit 1
fi

REPO_NAME=$(basename "$REPO_ROOT")
WORKTREE_DIR="$REPO_ROOT/.worktrees"

# Build worktree list: path | branch | label
build_list() {
  local entries=()
  entries+=("[+] Create new worktree")
  entries+=("[-] Remove worktree")

  while IFS= read -r line; do
    local wt_path wt_branch
    wt_path=$(echo "$line" | awk '{print $1}')
    wt_branch=$(echo "$line" | sed -n 's/.*\[\(.*\)\]/\1/p')

    if [[ "$wt_path" == "$REPO_ROOT" ]]; then
      entries+=("* $wt_branch  ($wt_path)")
    else
      entries+=("  $wt_branch  ($wt_path)")
    fi
  done < <(git worktree list)

  printf '%s\n' "${entries[@]}"
}

# Open or switch to a tmux window for the given worktree
open_window() {
  local wt_path="$1"
  local wt_branch="$2"
  local win_name="$REPO_NAME/$wt_branch"

  # sanitize window name
  win_name=$(echo "$win_name" | tr ":/. " "____")

  # check if window already exists in current session
  if tmux list-windows -F "#{window_name}" | grep -qx "$win_name"; then
    tmux select-window -t "$win_name"
  else
    tmux neww -n "$win_name" -c "$wt_path"
  fi
}

# Create a new worktree from a branch
create_worktree() {
  # list local + remote branches, deduplicate
  local branch
  branch=$(git branch -a --format='%(refname:short)' | sed 's|^origin/||' | sort -u | fzf --prompt="Branch: " --height=40% --border)

  if [[ -z "$branch" ]]; then
    echo "No branch selected"
    exit 0
  fi

  local wt_path="$WORKTREE_DIR/$branch"

  if [[ -d "$wt_path" ]]; then
    echo "Worktree already exists: $wt_path"
    open_window "$wt_path" "$branch"
    exit 0
  fi

  mkdir -p "$(dirname "$wt_path")"

  # check if branch exists locally
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    git worktree add "$wt_path" "$branch"
  else
    # create new local branch tracking remote
    git worktree add "$wt_path" -b "$branch" "origin/$branch" 2>/dev/null \
      || git worktree add "$wt_path" -b "$branch"
  fi

  open_window "$wt_path" "$branch"
}

# Remove a worktree
remove_worktree() {
  local entries=()

  while IFS= read -r line; do
    local wt_path
    wt_path=$(echo "$line" | awk '{print $1}')
    # skip main worktree
    [[ "$wt_path" == "$REPO_ROOT" ]] && continue
    local wt_branch
    wt_branch=$(echo "$line" | sed -n 's/.*\[\(.*\)\]/\1/p')
    entries+=("$wt_branch  ($wt_path)")
  done < <(git worktree list)

  if [[ ${#entries[@]} -eq 0 ]]; then
    echo "No removable worktrees"
    exit 0
  fi

  local selected
  selected=$(printf '%s\n' "${entries[@]}" | fzf --prompt="Remove worktree: " --height=40% --border)

  if [[ -z "$selected" ]]; then
    exit 0
  fi

  local wt_path
  wt_path=$(echo "$selected" | sed -n 's/.*(\(.*\))/\1/p')
  local wt_branch
  wt_branch=$(echo "$selected" | sed 's/  .*//')
  local win_name="$REPO_NAME/$wt_branch"
  win_name=$(echo "$win_name" | tr ":/. " "____")

  # kill tmux window if it exists
  if tmux list-windows -F "#{window_name}" | grep -qx "$win_name"; then
    tmux kill-window -t "$win_name"
  fi

  git worktree remove "$wt_path"
  echo "Removed worktree: $wt_branch"
}

# Main
selected=$(build_list | fzf --prompt="Worktree: " --height=40% --border --ansi)

if [[ -z "$selected" ]]; then
  exit 0
fi

case "$selected" in
  "[+] Create new worktree")
    create_worktree
    ;;
  "[-] Remove worktree")
    remove_worktree
    ;;
  *)
    wt_path=$(echo "$selected" | sed -n 's/.*(\(.*\))/\1/p')
    wt_branch=$(echo "$selected" | sed 's/^[* ]*//' | sed 's/  .*//')
    open_window "$wt_path" "$wt_branch"
    ;;
esac
